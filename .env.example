# Grill Gasten — kopieer naar .env.local voor lokaal development
# Op Vercel: zelfde variabelen in Project → Settings → Environment Variables

# E-mail via Resend (primair als key gezet)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="Grill Gasten <boekingen@grillgasten.eu>"
INQUIRY_TO=info@grillgasten.eu

# Formspree — https://formspree.io/f/xaqknnzj (fallback / zonder Resend)
FORMSPREE_FORM_ID=xaqknnzj

# Supabase — https://supabase.com/dashboard (SQL: supabase/migrations/)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mollie — https://my.mollie.com/dashboard (test_... of live_...)
MOLLIE_API_KEY=test_xxxxxxxx

# Keukenscherm /api/kitchen/* (lange random string)
KITCHEN_SECRET=

# Bezorging — vertrekpunt Klaaswaal (nooit NEXT_PUBLIC_)
DELIVERY_ORIGIN_LABEL=Klaaswaal
DELIVERY_ORIGIN_LAT=51.7725
DELIVERY_ORIGIN_LNG=4.4456
DELIVERY_QUOTE_SECRET=

# Optioneel: Google Distance Matrix voor nauwkeurige rijafstand
# GOOGLE_MAPS_API_KEY=
